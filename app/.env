# --------------------
# Provider selection
# --------------------
# groq / gemini / google / openai / openai_compatible / anthropic / claude
AI_PROVIDER=groq

# --------------------
# Groq settings (OpenAI-compatible API)
# --------------------
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile
# Optional override (default shown)
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --------------------
# Gemini (Google) settings
# --------------------
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# --------------------
# OpenAI (or OpenAI-compatible) settings
# --------------------
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini
# For OpenAI-compatible providers (OpenRouter, etc), set base URL.
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --------------------
# Anthropic / Claude settings
# --------------------
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# Keep this 0 to fail loudly if live AI call fails (recommended).
# Set to 1 only for demo/offline fallback text.
ALLOW_AI_FALLBACK=0

# Optional server port.
PORT=5000